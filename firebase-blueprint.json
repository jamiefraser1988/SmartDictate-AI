{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to user's profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "A single transformation history item",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the history item" },
        "uid": { "type": "string", "description": "ID of the user who owns this item" },
        "timestamp": { "type": "number", "description": "When the item was created" },
        "input": { "type": "string", "description": "The original input text" },
        "output": { "type": "string", "description": "The transformed output text" },
        "format": { "type": "string", "enum": ["transcript", "minutes", "tasks", "email"], "description": "The transformation format used" }
      },
      "required": ["id", "uid", "timestamp", "input", "output", "format"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/history/{itemId}": {
      "schema": "HistoryItem",
      "description": "Transformation history items"
    }
  }
}
